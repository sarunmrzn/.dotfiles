[global]
monitor = 0
follow = mouse
width = (300, 600)
height = 300
offset = 20x20
origin = top-right
notification_limit = 5
padding = 16
horizontal_padding = 12
frame_width = 2
separator_height = 2
corner_radius = 8
idle_threshold = 120
font = JetBrainsMono Nerd Font 10

background = "#1a1b26ee"
foreground = "#c0caf5ff"
frame_color = "#7aa2f7aa"
separator_color = frame

# Add transparency (0-100)
transparency = 20

# Improve corner radius for modern look
corner_radius = 8

# Optional: Add subtle shadow
shadow = true
shadow_opacity = .75

[urgency_low]
background = "#1a1b26"
foreground = "#565f89"
frame_color = "#7dcfff"
timeout = 5

[urgency_normal]
background = "#24283b"
foreground = "#c0caf5"
frame_color = "#7aa2f7"
timeout = 8

[urgency_critical]
background = "#f7768e"
foreground = "#1a1b26"
frame_color = "#f7768e"
timeout = 0

# Add rule to block Spotify notifications
[spotify]
    appname = "Spotify"
    skip_display = yes
    history_ignore = yes